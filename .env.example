# База данных
DATABASE_URL=postgresql://user:password@db:5432/yurayt_crm

# Настройки FastAPI
ENV=development
SECRET_KEY=your-super-secret-key-for-jwt-or-sessions

# Интеграция с Keycloak (валидация токенов бэкендом)
KEYCLOAK_ISSUER=https://id.you-right.ru/realms/You-right
KEYCLOAK_CLIENT_ID=yurayt-dela
KEYCLOAK_CLIENT_SECRET=секрет_из_панели_keycloak

# Настройки NextAuth (для фронтенд-слоя)
NEXTAUTH_URL=https://dela.you-right.ru
NEXTAUTH_SECRET=openssl_rand_base64_output_here

# Внешние интеграции
YOU_RIGHT_API_KEY=api_ключ_для_api.you-right.ru
BILLING_WEBHOOK_SECRET=секрет_для_проверки_запросов_от_хаба
CRON_SECRET=секрет_для_триггеров_синхронизации

# PostgreSQL (используется сервисом db в docker-compose)
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=yurayt_crm
